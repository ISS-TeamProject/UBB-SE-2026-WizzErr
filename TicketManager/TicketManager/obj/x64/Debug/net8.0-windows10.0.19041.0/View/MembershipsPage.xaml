<?xml version="1.0" encoding="utf-8"?>
<Page x:ConnectionId='1'
    x:Class="TicketManager.View.MembershipsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:TicketManager.ViewModel"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Background="Transparent" Padding="40">
        <StackPanel Spacing="20" HorizontalAlignment="Center">

            <TextBlock Text="Choose Your Membership" FontSize="32" FontWeight="Bold" Foreground="#2bb8c0" HorizontalAlignment="Center"/>
            <TextBlock Text="Unlock exclusive flight discounts and premium perks." FontSize="16" Foreground="Gray" HorizontalAlignment="Center"/>

            <GridView x:ConnectionId='2' x:Name="membershipGridView"                                                           SelectionMode="None" HorizontalAlignment="Center" Margin="0,30,0,0">
                <GridView.ItemTemplate>
                    <DataTemplate                                       >

                        <Border x:ConnectionId='4' Width="260" Height="320" Margin="15" CornerRadius="16"                                  BorderThickness="2" Background="White">
                            <Grid Padding="24">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock x:ConnectionId='5' Grid.Row="0"                      FontSize="32" FontWeight="Bold"                                 HorizontalAlignment="Center"/>

                                <StackPanel Grid.Row="1" VerticalAlignment="Center" Spacing="12">
                                    <TextBlock x:ConnectionId='7'                              FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Center"/>

                                    <ItemsControl x:ConnectionId='8'                                     >
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding}" FontSize="14" Foreground="Gray" HorizontalAlignment="Center" Margin="0,3,0,3"/>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>

                                <Button x:ConnectionId='6' Grid.Row="2" Content="Purchase" 
                                        Command="{Binding DataContext.PurchaseCommand, ElementName=membershipGridView}"                                         
                                                                        Foreground="White" FontWeight="Bold" 
                                        Width="200" Height="40" CornerRadius="8" HorizontalAlignment="Center"/>
                            </Grid>
                        </Border>

                    </DataTemplate>
                </GridView.ItemTemplate>
            </GridView>

        </StackPanel>
    </Grid>
</Page>

