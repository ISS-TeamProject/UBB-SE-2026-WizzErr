<?xml version="1.0" encoding="utf-8"?>
<Page x:ConnectionId='1'
    x:Class="TicketManager.View.AuthPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:TicketManager.View"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Background="Transparent">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="20">

            <!-- Title and subtitle bound to ViewModel (previously set in code-behind) -->
            <TextBlock x:ConnectionId='2'                                                  FontSize="32" FontWeight="Bold" Foreground="#2bb8c0" HorizontalAlignment="Center"/>
            <TextBlock x:ConnectionId='3'                                                     FontSize="16" Foreground="Gray" HorizontalAlignment="Center"/>

            <!-- Email: two-way bound to ViewModel -->
            <TextBox x:ConnectionId='4' x:Name="emailInput" PlaceholderText="Email" Width="300" 
                                                                                                           
                     InputScope="EmailSmtpAddress" />

            <!-- Username/Phone: visibility bound to IsRegisterFieldsVisible -->
            <TextBox x:ConnectionId='5' x:Name="usernameInput" PlaceholderText="Username" Width="300" 
                                                                                                             
                                                                                          />
            <TextBox x:ConnectionId='6' x:Name="phoneInput" PlaceholderText="Phone Number" Width="300" 
                                                                                                          
                     InputScope="TelephoneNumber"
                                                                                          />

            <!-- Password (PasswordBox doesn't support two-way binding, synced in code-behind) -->
            <PasswordBox x:ConnectionId='7' x:Name="passwordInput" PlaceholderText="Password" Width="300" 
                                                                    />

            <!-- Action button: label and command bound to ViewModel -->
            <Button x:ConnectionId='8'                                                             
                                                              
                    Background="#2bb8c0" Foreground="White" 
                    Width="300" Height="40" CornerRadius="8" 
                    FontWeight="Bold" Margin="0,10,0,0"
                    HorizontalAlignment="Center" HorizontalContentAlignment="Center"/>

            <!-- Toggle link: labels bound to ViewModel, command handles mode switch -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="5" Margin="0,10,0,0">
                <TextBlock x:ConnectionId='9'                                                          VerticalAlignment="Center" Foreground="Gray"/>
                <HyperlinkButton x:ConnectionId='10'                                                             
                                                                               
                                 Foreground="#2bb8c0" FontWeight="SemiBold"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Page>

